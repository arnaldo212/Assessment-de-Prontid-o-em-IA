# Copie para .env e preencha com valores reais antes de subir o compose.


DB_USER=assessment
DB_PASSWORD=troque-esta-senha
DB_NAME=assessment
DB_HOST=db
DB_PORT=5432

JWT_SECRET=troque-por-uma-string-longa-e-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Só usadas em produção (docker-compose.prod.yml) ---
# URL pública onde o BACKEND vai ficar acessível a partir do navegador
# do usuário (não localhost!). É gravada dentro do bundle do frontend
# no momento do build, então precisa estar certa antes de buildar.
#PUBLIC_API_URL=https://api.seudominio.com

# URL pública exata do FRONTEND — restringe o CORS do backend para
# aceitar requisições só dessa origem.
#CORS_ORIGINS=https://assessment.seudominio.com
